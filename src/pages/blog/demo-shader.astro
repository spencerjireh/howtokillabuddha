---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ShaderCanvas from '@/art/components/ShaderCanvas';
import { getEntry, render } from 'astro:content';

const post = await getEntry('blog', 'demo-shader');
if (!post) throw new Error('Post not found: demo-shader');

const { Content } = await render(post);

// Import shader source as raw string
const shaderSource = await import('./demo-shader/shaders/demo.frag?raw').then(m => m.default);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogImage={post.data.ogImage}
  ogType="article"
  themeColor={post.data.theme === 'dark' ? '#0a0a0a' : '#f5f5f0'}
>
  <div class="post-page" data-theme={post.data.theme}>
    <!-- Art region -->
    <div class="hero" data-pagefind-ignore>
      <ShaderCanvas
        client:visible
        fragmentSource={shaderSource}
        className="hero__canvas"
        fallbackGradient="linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #0a0a0a 100%)"
      />
      <div class="hero__overlay">
        <h1 class="hero__title">{post.data.title}</h1>
        <div class="hero__meta">
          <span class="hero__category">{post.data.category}</span>
          <time datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
        </div>
      </div>
    </div>

    <!-- Navigation -->
    <nav class="post-nav">
      <a href="/" class="post-nav__back">&larr; back</a>
    </nav>

    <!-- Content region -->
    <main id="main-content" data-pagefind-body>
      <article class="prose">
        <Content />
      </article>
    </main>
  </div>
</BaseLayout>

<style>
  .post-page {
    min-height: 100dvh;
  }

  /* ---- Hero / Art Region ---- */

  .hero {
    position: relative;
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    height: 60vh;
    min-height: 400px;
    overflow: hidden;
  }

  .hero :global(.hero__canvas) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero__overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-l) var(--page-padding);
    background: linear-gradient(transparent, rgba(10, 10, 10, 0.85));
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    max-width: var(--content-width);
    margin-inline: auto;
  }

  .hero__title {
    font-size: var(--text-2xl);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: #e5e5e0;
  }

  .hero__meta {
    display: flex;
    gap: var(--space-xs);
    margin-block-start: var(--space-2xs);
    font-size: var(--text-sm);
    color: #8a8a8a;
  }

  .hero__category {
    text-transform: uppercase;
    font-size: var(--text-xs);
    letter-spacing: 0.05em;
  }

  /* ---- Navigation ---- */

  .post-nav {
    padding-block: var(--space-m);
    border-bottom: 1px solid var(--color-border);
    margin-block-end: var(--space-l);
  }

  .post-nav__back {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .post-nav__back:hover {
    color: var(--color-text);
  }

  /* ---- Content ---- */

  article {
    padding-block-end: var(--space-2xl);
  }
</style>
